generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int                @id @default(autoincrement())
  name        String
  email       String             @unique
  password    String
  branch      String?
  year        Int?
  role        String             @default("student")
  attempts    QuizAttempt[]
  submissions Submission[]
  interviews  InterviewSession[]
  createdAt   DateTime           @default(now())
}

model Quiz {
  id         Int            @id @default(autoincrement())
  title      String
  topic      String
  difficulty String
  questions  QuizQuestion[]
  attempts   QuizAttempt[]
  createdAt  DateTime       @default(now())
}

model QuizQuestion {
  id         Int      @id @default(autoincrement())
  quiz       Quiz     @relation(fields: [quizId], references: [id])
  quizId     Int
  question   String
  options    Json
  correctAns String
  createdAt  DateTime @default(now())
}

model QuizAttempt {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  quiz       Quiz     @relation(fields: [quizId], references: [id])
  quizId     Int
  score      Int
  total      Int
  percentage Float
  createdAt  DateTime @default(now())
}

model CodingQuestion {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  difficulty  String
  testCases   Json

  createdAt   DateTime     @default(now())
  submissions Submission[]
}

model Submission {
  id          Int            @id @default(autoincrement())
  user        User           @relation(fields: [userId], references: [id])
  userId      Int
  question    CodingQuestion @relation(fields: [questionId], references: [id])
  questionId  Int
  language    String
  code        String
  passedCases Int
  totalCases  Int
  score       Float
  createdAt   DateTime       @default(now())
  percentage  Float
}

model InterviewSession {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  topic     String
  feedback  String
  score     Int
  createdAt DateTime @default(now())
}
model ActivityLog{
  id Int @id @default(autoincrement())
  userId Int?
  action String
  entity String?
  entityId Int?
  createdAt DateTime @default(now())
}
